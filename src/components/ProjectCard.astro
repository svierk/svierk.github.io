---
import type { Project } from '../data/projects';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  project: Project;
  lang: Lang;
}

const { project, lang } = Astro.props;
const t = useTranslations(lang);
const url = `https://github.com/svierk/${project.repo}`;
---

<article class="card project">
  <div class="head">
    <h3>
      <a href={url} target="_blank" rel="noopener noreferrer">{project.repo}</a>
    </h3>
    <span class="stars muted" title={`${project.stars} ${t('opensource.stars')}`}>
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="m12 17.27 6.18 3.73-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27Z" />
      </svg>
      {project.stars}
    </span>
  </div>
  <p class="description">{project.description[lang]}</p>
  <ul class="topics">
    {project.topics.map((topic) => <li class="chip">{topic}</li>)}
  </ul>
</article>

<style>
  .project {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
  }

  h3 {
    font-size: 1.05rem;
    margin: 0;
    word-break: break-word;
  }

  .stars {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .description {
    margin: 0;
    font-size: 0.95rem;
    flex-grow: 1;
  }

  .topics {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.4rem 0 0;
    padding: 0;
  }
</style>
