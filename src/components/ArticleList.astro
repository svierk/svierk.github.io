---
import type { Article } from '../lib/medium';
import type { Lang } from '../i18n/ui';
import { formatDate, useTranslations } from '../i18n/utils';

interface Props {
  articles: Article[];
  mediumUrl: string;
  lang: Lang;
}

const { articles, mediumUrl, lang } = Astro.props;
const t = useTranslations(lang);
---

{
  articles.length > 0 ? (
    <>
      <ul class="articles">
        {articles.map((article) => (
          <li class="card">
            <a href={article.url} target="_blank" rel="noopener noreferrer">
              {article.image && <img class="thumb" src={article.image} alt="" loading="lazy" width="84" height="84" />}
              <span class="text">
                <span class="title">{article.title}</span>
                <time class="muted" datetime={article.date.toISOString()}>
                  {formatDate(article.date, lang)}
                </time>
              </span>
            </a>
          </li>
        ))}
      </ul>
      <p class="view-all">
        <a href={mediumUrl} target="_blank" rel="noopener noreferrer">
          {t('blog.viewAll')} →
        </a>
      </p>
    </>
  ) : (
    <p>
      <a href={mediumUrl} target="_blank" rel="noopener noreferrer">
        {t('blog.fallback')} →
      </a>
    </p>
  )
}

<style>
  .articles {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .articles .card {
    padding: 0;
    overflow: hidden;
  }

  .articles a {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    padding: 0.75rem 1.4rem 0.75rem 0.75rem;
    color: var(--text);
  }

  .articles a:hover {
    text-decoration: none;
  }

  .articles a:hover .title {
    color: var(--accent);
  }

  .thumb {
    flex-shrink: 0;
    width: 84px;
    height: 84px;
    object-fit: cover;
    border-radius: 10px;
    border: 1px solid var(--border);
  }

  .text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }

  .title {
    font-weight: 600;
  }

  time {
    font-size: 0.88rem;
  }

  .view-all {
    margin-top: 1.25rem;
  }
</style>
