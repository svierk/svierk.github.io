---
import type { Talk } from '../data/talks';
import type { Lang } from '../i18n/ui';
import { formatDate, useTranslations } from '../i18n/utils';

interface Props {
  talk: Talk;
  lang: Lang;
  upcoming: boolean;
}

const { talk, lang, upcoming } = Astro.props;
const t = useTranslations(lang);

const start = new Date(talk.date);
const end = talk.dateEnd ? new Date(talk.dateEnd) : undefined;
const dateLabel = end
  ? `${formatDate(start, lang, { day: 'numeric', month: 'long', year: undefined })} – ${formatDate(end, lang)}`
  : formatDate(start, lang);
---

<article class:list={['card', 'talk', { upcoming }]}>
  <div class="head">
    <h3>
      {talk.url ? (
        <a href={talk.url} target="_blank" rel="noopener noreferrer">
          {talk.event}
        </a>
      ) : (
        talk.event
      )}
    </h3>
    {upcoming && <span class="chip">{t('speaking.upcoming')}</span>}
  </div>
  <p class="muted meta">
    {dateLabel} · <span class="flag" aria-hidden="true">{talk.flag}</span> {talk.location}
  </p>
  {
    talk.comingSoon ? (
      <p class="session muted">{t('speaking.comingSoon')}</p>
    ) : (
      <ul class="sessions">
        {talk.sessions.map((session) => (
          <li>
            <span class="session-title">“{session.title}”</span>
            {(session.repo || session.slides || session.article) && (
              <span class="links">
                {session.repo && (
                  <a class="link-chip" href={session.repo} target="_blank" rel="noopener noreferrer">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55 0-.27-.01-1.17-.02-2.12-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.03 1.75 2.69 1.25 3.34.95.1-.74.4-1.25.72-1.53-2.55-.29-5.23-1.28-5.23-5.68 0-1.26.45-2.28 1.18-3.09-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.16 1.18a11 11 0 0 1 5.76 0c2.19-1.49 3.15-1.18 3.15-1.18.63 1.58.23 2.75.12 3.04.73.81 1.18 1.83 1.18 3.09 0 4.41-2.69 5.38-5.25 5.67.41.35.77 1.05.77 2.12 0 1.53-.01 2.76-.01 3.14 0 .3.2.67.8.55A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
                    </svg>
                    {t('speaking.code')}
                  </a>
                )}
                {session.slides && (
                  <a class="link-chip" href={session.slides} target="_blank" rel="noopener noreferrer">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z" />
                      <path d="M14 2v6h6M16 13H8M16 17H8M10 9H8" />
                    </svg>
                    {t('speaking.slides')}
                  </a>
                )}
                {session.article && (
                  <a class="link-chip" href={session.article} target="_blank" rel="noopener noreferrer">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M13.54 12a6.8 6.8 0 0 1-6.77 6.82A6.8 6.8 0 0 1 0 12a6.8 6.8 0 0 1 6.77-6.82A6.8 6.8 0 0 1 13.54 12Zm7.42 0c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42ZM24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12Z" />
                    </svg>
                    {t('speaking.article')}
                  </a>
                )}
              </span>
            )}
          </li>
        ))}
      </ul>
    )
  }
</article>

<style>
  .talk {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .talk.upcoming {
    border-color: color-mix(in srgb, var(--accent) 45%, var(--border));
    box-shadow: 0 0 26px var(--accent-glow);
  }

  .flag {
    font-size: 1rem;
  }

  .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
  }

  h3 {
    font-size: 1.12rem;
    margin: 0;
  }

  h3 a {
    color: var(--text);
  }

  h3 a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .meta {
    font-size: 0.9rem;
    margin: 0;
  }

  .sessions {
    list-style: none;
    margin: 0.35rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .sessions li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .links {
    display: inline-flex;
    gap: 0.4rem;
  }

  .link-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.1rem 0.6rem;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .link-chip:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }

  .session {
    margin: 0.35rem 0 0;
    font-style: italic;
  }
</style>
