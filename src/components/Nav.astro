---
import { profile } from '../data/profile';
import type { Lang } from '../i18n/ui';
import { altLangPath, homePath, useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const home = homePath(lang);
const alt = altLangPath(lang);

const links = [
  { href: `${home}#about`, label: t('nav.about') },
  { href: `${home}#speaking`, label: t('nav.speaking') },
  { href: `${home}#sessions`, label: t('nav.sessions') },
  { href: `${home}#blog`, label: t('nav.blog') },
  { href: `${home}#opensource`, label: t('nav.opensource') },
];
---

<header>
  <nav class="container" aria-label="Main">
    <a class="brand" href={home}>{profile.name}</a>
    <ul class="links">
      {
        links.map((link) => (
          <li>
            <a href={link.href}>{link.label}</a>
          </li>
        ))
      }
    </ul>
    <div class="actions">
      <a class="lang-switch" href={alt.path} aria-label={alt.lang === 'de' ? 'Deutsche Version' : 'English version'}>
        {alt.lang.toUpperCase()}
      </a>
      <button id="theme-toggle" type="button" aria-label="Toggle color theme">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
    document.documentElement.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 4rem;
  }

  .brand {
    font-weight: 700;
    color: var(--text);
    white-space: nowrap;
  }

  .brand:hover {
    text-decoration: none;
    color: var(--accent);
  }

  .links {
    display: flex;
    gap: 1.25rem;
    list-style: none;
    margin: 0 auto;
    padding: 0;
  }

  .links a {
    color: var(--text-muted);
    font-size: 0.95rem;
    font-weight: 500;
  }

  .links a:hover {
    color: var(--text);
    text-decoration: none;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
  }

  .lang-switch {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.3rem 0.55rem;
  }

  .lang-switch:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }

  #theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.15rem;
    height: 2.15rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
  }

  #theme-toggle:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .icon-sun {
    display: none;
  }

  :global([data-theme='light']) .icon-sun {
    display: none;
  }

  :global([data-theme='dark']) .icon-sun {
    display: block;
  }

  :global([data-theme='dark']) .icon-moon {
    display: none;
  }

  @media (max-width: 720px) {
    .links {
      display: none;
    }

    .actions {
      margin-left: auto;
    }
  }
</style>
