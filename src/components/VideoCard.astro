---
import type { LiveSession } from '../data/sessions';
import type { Lang } from '../i18n/ui';
import { formatDate, useTranslations } from '../i18n/utils';

interface Props {
  session: LiveSession;
  lang: Lang;
}

const { session, lang } = Astro.props;
const t = useTranslations(lang);
const videoUrl = `https://www.youtube.com/watch?v=${session.videoId}`;
const thumbnail = `https://img.youtube.com/vi/${session.videoId}/hqdefault.jpg`;
---

<article class="card video">
  <a class="thumb" href={videoUrl} target="_blank" rel="noopener noreferrer" aria-label={`${t('sessions.watch')}: ${session.title}`}>
    <img src={thumbnail} alt="" loading="lazy" width="480" height="360" />
    <span class="play" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5.14v13.72L19 12 8 5.14Z"/></svg>
    </span>
  </a>
  <div class="body">
    <h3>
      <a href={videoUrl} target="_blank" rel="noopener noreferrer">{session.title}</a>
    </h3>
    <p class="muted meta">
      @{session.host} · {formatDate(new Date(session.date), lang, { day: undefined })}
    </p>
    <p class="description">{session.description[lang]}</p>
  </div>
</article>

<style>
  .video {
    padding: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .thumb {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .thumb:hover img {
    transform: scale(1.04);
  }

  .play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: #fff;
    background: rgba(0, 0, 0, 0.25);
    opacity: 0.9;
    transition: opacity 0.2s ease;
  }

  .play svg {
    background: rgba(0, 0, 0, 0.6);
    border-radius: 50%;
    padding: 0.7rem;
    width: 2.6rem;
    height: 2.6rem;
  }

  .body {
    padding: 1.1rem 1.3rem 1.3rem;
  }

  h3 {
    font-size: 1.05rem;
    margin: 0 0 0.2rem;
  }

  h3 a {
    color: var(--text);
  }

  h3 a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .meta {
    font-size: 0.88rem;
    margin: 0 0 0.5rem;
  }

  .description {
    margin: 0;
    font-size: 0.95rem;
  }
</style>
