---
import type { LiveSession } from '../data/sessions';
import type { Lang } from '../i18n/ui';
import { formatDate, useTranslations } from '../i18n/utils';

interface Props {
  session: LiveSession;
  lang: Lang;
}

const { session, lang } = Astro.props;
const t = useTranslations(lang);
const videoUrl = `https://www.youtube.com/watch?v=${session.videoId}`;
const thumbnail = `https://img.youtube.com/vi/${session.videoId}/hqdefault.jpg`;
---

<article class="card video">
  <a class="thumb" href={videoUrl} target="_blank" rel="noopener noreferrer" aria-label={`${t('sessions.watch')}: ${session.title}`}>
    <img src={thumbnail} alt="" loading="lazy" width="480" height="360" />
    <span class="play" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5.14v13.72L19 12 8 5.14Z"/></svg>
    </span>
  </a>
  <div class="body">
    <h3>
      <a href={videoUrl} target="_blank" rel="noopener noreferrer">{session.title}</a>
    </h3>
    <p class="muted meta">
      @{session.host} · {formatDate(new Date(session.date), lang, { day: undefined })}
    </p>
    <p class="description">{session.description[lang]}</p>
    {
      (session.repo || session.article) && (
        <span class="links">
          {session.repo && (
            <a class="link-chip" href={session.repo} target="_blank" rel="noopener noreferrer">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55 0-.27-.01-1.17-.02-2.12-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.03 1.75 2.69 1.25 3.34.95.1-.74.4-1.25.72-1.53-2.55-.29-5.23-1.28-5.23-5.68 0-1.26.45-2.28 1.18-3.09-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.16 1.18a11 11 0 0 1 5.76 0c2.19-1.49 3.15-1.18 3.15-1.18.63 1.58.23 2.75.12 3.04.73.81 1.18 1.83 1.18 3.09 0 4.41-2.69 5.38-5.25 5.67.41.35.77 1.05.77 2.12 0 1.53-.01 2.76-.01 3.14 0 .3.2.67.8.55A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
              </svg>
              {t('speaking.code')}
            </a>
          )}
          {session.article && (
            <a class="link-chip" href={session.article} target="_blank" rel="noopener noreferrer">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M13.54 12a6.8 6.8 0 0 1-6.77 6.82A6.8 6.8 0 0 1 0 12a6.8 6.8 0 0 1 6.77-6.82A6.8 6.8 0 0 1 13.54 12Zm7.42 0c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42ZM24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12Z" />
              </svg>
              {t('speaking.article')}
            </a>
          )}
        </span>
      )
    }
  </div>
</article>

<style>
  .video {
    padding: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .thumb {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .thumb:hover img {
    transform: scale(1.04);
  }

  .play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: #fff;
    background: rgba(0, 0, 0, 0.25);
    opacity: 0.9;
    transition: opacity 0.2s ease;
  }

  .play svg {
    background: rgba(0, 0, 0, 0.6);
    border-radius: 50%;
    padding: 0.7rem;
    width: 2.6rem;
    height: 2.6rem;
  }

  .body {
    padding: 1.1rem 1.3rem 1.3rem;
  }

  h3 {
    font-size: 1.05rem;
    margin: 0 0 0.2rem;
  }

  h3 a {
    color: var(--text);
  }

  h3 a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .meta {
    font-size: 0.88rem;
    margin: 0 0 0.5rem;
  }

  .description {
    margin: 0;
    font-size: 0.95rem;
  }

  .links {
    display: inline-flex;
    gap: 0.4rem;
    margin-top: 0.7rem;
  }

  .link-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.1rem 0.6rem;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .link-chip:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }
</style>
