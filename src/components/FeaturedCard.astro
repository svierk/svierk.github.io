---
import type { Feature } from '../data/featured';
import type { Lang } from '../i18n/ui';
import { formatDate, useTranslations } from '../i18n/utils';

interface Props {
  feature: Feature;
  lang: Lang;
}

const { feature, lang } = Astro.props;
const t = useTranslations(lang);

const dateLabel = feature.date ? formatDate(new Date(feature.date), lang) : undefined;
const meta = [feature.series, feature.host ? `${t('featured.with')} ${feature.host}` : undefined, dateLabel]
  .filter(Boolean)
  .join(' · ');
---

<article class:list={['card', 'feature', { comingSoon: feature.comingSoon }]}>
  <div class="head">
    <span class="publisher">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.55V9h3.57v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0Z" />
      </svg>
      {t('featured.by')} {feature.publisher}
    </span>
    {feature.comingSoon && <span class="chip">{t('featured.comingSoon')}</span>}
  </div>
  {meta && <p class="muted meta">{meta}</p>}
  <h3>
    {feature.url ? (
      <a href={feature.url} target="_blank" rel="noopener noreferrer">
        {feature.title[lang]}
      </a>
    ) : (
      feature.title[lang]
    )}
  </h3>
  <p class="description">{feature.description[lang]}</p>
  {
    feature.url && (
      <a class="link-chip" href={feature.url} target="_blank" rel="noopener noreferrer">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
          <path d="M15 3h6v6M10 14 21 3" />
        </svg>
        {t('featured.watch')}
      </a>
    )
  }
</article>

<style>
  .feature {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .feature.comingSoon {
    border-color: color-mix(in srgb, var(--accent) 45%, var(--border));
    box-shadow: 0 0 26px var(--accent-glow);
    animation: feature-pulse 3s ease-in-out infinite;
  }

  @keyframes feature-pulse {
    0%,
    100% {
      box-shadow: 0 0 18px var(--accent-glow);
    }
    50% {
      box-shadow: 0 0 30px var(--accent-glow);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .feature.comingSoon {
      animation: none;
    }
  }

  .head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .publisher {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
  }

  .meta {
    font-size: 0.88rem;
    margin: 0.35rem 0 0;
  }

  h3 {
    font-size: 1.12rem;
    margin: 0.15rem 0 0;
  }

  h3 a {
    color: var(--text);
  }

  h3 a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .description {
    margin: 0.4rem 0 0;
    font-size: 0.95rem;
  }

  .link-chip {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-top: 0.8rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.1rem 0.6rem;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .link-chip:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }
</style>
